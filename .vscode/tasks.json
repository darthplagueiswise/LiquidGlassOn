{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build WATweaks dylib (fast, no clean)",
            "type": "shell",
            "command": "./build.sh dylib --fast",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "icon": {
                "color": "terminal.ansiCyan",
                "id": "run-all"
            }
        },
        {
            "label": "Build WATweaks rootless .deb",
            "type": "shell",
            "command": "./build.sh rootless",
            "group": {
                "kind": "build"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "icon": {
                "id": "package"
            }
        },
        {
            "label": "Build WATweaks SideStore IPA",
            "type": "shell",
            "command": "./build.sh sidestore",
            "group": {
                "kind": "build"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true
            },
            "icon": {
                "id": "cloud-download"
            }
        },
        {
            "label": "Launch pymobiledevice3 device tunnel",
            "type": "shell",
            "command": "sudo pymobiledevice3 remote tunneld",
            "group": {
                "kind": "build"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated",
                "clear": true
            },
            "icon": {
                "color": "terminal.ansiYellow",
                "id": "debug-connected"
            }
        }
    ]
}
